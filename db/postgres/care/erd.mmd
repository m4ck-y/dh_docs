erDiagram
    %% CARE SCHEMA
    %% Relaciones de responsable/cuidado

    %% RELACIONES
    person ||--o{ person_responsible : "is_dependent"
    person ||--o{ person_responsible : "is_responsible"

    %% ENUMS
    %% ERelationship: tipo de relacion (MOTHER, FATHER, CAREGIVER, LEGAL_GUARDIAN, OTHER)
    %% ECareRole: rol del cuidador (LIVES_WITH_AND_CARES, CARES_NOT_LIVING_WITH, ADMINISTRATIVE_SUPPORT_ONLY)
    %% EEconomicDependence: dependencia economica (YES, PARTIALLY, NO)
    ERelationship {
        String MOTHER "MOTHER"
        String FATHER "FATHER"
        String CAREGIVER "CAREGIVER"
        String LEGAL_GUARDIAN "LEGAL_GUARDIAN"
        String OTHER "OTHER"
    }

    ECareRole {
        String LIVES_WITH_AND_CARES "LIVES_WITH_AND_CARES"
        String CARES_NOT_LIVING_WITH "CARES_NOT_LIVING_WITH"
        String ADMINISTRATIVE_SUPPORT_ONLY "ADMINISTRATIVE_SUPPORT_ONLY"
    }

    EEconomicDependence {
        String YES "YES"
        String PARTIALLY "PARTIALLY"
        String NO "NO"
    }

    %% ENTIDADES
    %% person_responsible: vinculacion responsable-dependiente
    %% id_dependent: persona que depende (paciente)
    %% id_responsible: responsable o tutor
    %% economic_dependence: dependencia economica del responsable hacia el dependiente
    person_responsible {
        UUID id PK
        UUID id_dependent FK
        UUID id_responsible FK
        Enum(ERelationship) type_relationship
        Enum(ECareRole) care_role
        Enum(EEconomicDependence) economic_dependence
        String(100) relationship_other
    }