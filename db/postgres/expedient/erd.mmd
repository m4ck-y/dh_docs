erDiagram
    %% EXPEDIENT SCHEMA
    %% Catalogo de documentos e identificadores

    %% REFERENCIAS EXTERNAS
    %% person: definida en schema people

    %% RELACIONES
    person ||--o{ document : "has"
    document_category ||--o{ document_type : "categorizes"
    document_type ||--o{ document : "defines_type"

    %% ENUMS
    %% EVerificationStatus: estado de verificacion (REJECTED, PENDING, APPROVED)
    EVerificationStatus {
        String REJECTED "REJECTED"
        String PENDING "PENDING"
        String APPROVED "APPROVED"
    }

    %% ENTIDADES
    %% document: documentos de identificacion y archivos
    %% verification_status: estado de verificacion del documento
    %% verified_by: usuario que verifico (FK a user o null)
    document {
        UUID id PK
        UUID id_person FK
        String url_file
        String url_thumbnail
        String title
        Text description
        UUID id_document_type FK
        Date issued_at
        Date expires_at
        Enum(EVerificationStatus) verification_status
        UUID verified_by FK
    }

    %% document_type: catalogo de tipos de documento
    %% id_category: categoria del tipo (FK a document_category)
    document_type {
        UUID id PK
        String name
        UUID id_category FK
    }

    %% document_category: categorias de documentos
    %% Ejemplo: Identificacion, Educacion, Medico, Laboral, Fiscal
    document_category {
        UUID id PK
        String name
    }