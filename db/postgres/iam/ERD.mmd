erDiagram
    %% IAM SCHEMA
    %% Control de acceso, roles y permisos (multi-tenant)
    %% Todas las entidades heredan de BaseModel (id, created_at, updated_at, deleted_at)
    %% Solo se muestran columnas especificas de cada entidad
    %% Excepcion: user_role y role_permission son tablas intermediarias N:N (no heredan BaseModel)

    %% REFERENCIAS EXTERNAS
    %% person: definida en schema people
    %% company: definida en schema organizations (opcional para tenants tipo COMPANY)

    %% RELACIONES
    tenant ||--o{ membership : "has"
    person ||--o{ membership : "belongs_to"
    membership ||--o{ user_role : "grants_context"
    role ||--o{ user_role : "assigned"
    role ||--o{ role_permission : "grants"
    permission ||--o{ role_permission : "included_in"
    resource ||--o{ permission : "defines_scope"
    operation ||--o{ permission : "defines_action"

    %% ENUMS
    EMembershipStatus {
        String PENDING "Invitación enviada"
        String ACTIVE "Acceso habilitado"
        String SUSPENDED "Acceso revocado temporalmente"
    }

    ETenantType {
        String SYSTEM "Sistema Core (Pacientes y configuración global)"
        String COMPANY "Entidad de Negocio (Hospitales, Clínicas, Farmacias)"
    }

    %% ENTIDADES
    %% tenant: El 'contenedor' de acceso (multi-tenant)
    %% type: Define si es el sistema global o una empresa privada
    %% id_company: Enlace al perfil de negocio si type == COMPANY
    tenant {
        String key "slug único (ej: hosp-central)"
        String name "Nombre visual"
        Enum(ETenantType) type "SYSTEM o COMPANY"
        Int id_company FK "NULL si es SYSTEM"
        Text description
    }

    %% membership: El vínculo de una Persona con una Organización
    %% Esta tabla permite que una persona sea 'Médico' en el Hospital A y 'Paciente' en el Sistema Global
    membership {
        UUID id_person FK
        UUID id_tenant FK
        Enum(EMembershipStatus) status
        DateTime invited_at
        DateTime accepted_at
    }

    %% role: Definición de conjunto de permisos
    %% Los roles pertenecen a un Tenant (un 'Admin' de un Hospital no es 'Admin' de otro)
    role {
        UUID id_tenant FK
        String key "identificador (ej: admin, doctor)"
        String name
        Text description
    }

    %% user_role: Asignación de roles a una membresía específica
    user_role {
        UUID id_membership FK
        UUID id_role FK
    }

    %% resource: Módulos o Áreas del sistema (ej: billing, records, users)
    resource {
        String key "Namespace (ej: core.patient)"
        String name
    }

    %% operation: Acciones permitidas (ej: create, read, update, delete)
    operation {
        String key "Verbo (ej: read)"
        String name
    }

    %% permission: La unión de Recurso + Operación (ej: core.patient.read)
    permission {
        UUID id_resource FK
        UUID id_operation FK
        String key "key_resource + '.' + key_operation"
        Text description
        Boolean is_active
    }

    %% role_permission: Los permisos que componen un rol
    role_permission {
        UUID id_role FK
        UUID id_permission FK
    }