erDiagram
    %% MFA SCHEMA
    %% Autenticacion multifactor
    %% BaseModel (heredado por todas las entidades):
    %%   id Integer PK autoincrement — interno, NUNCA expuesto en API
    %%   uuid UUID auto-generado    — externo, usado en respuestas y rutas de API
    %%   created_at / updated_at / deleted_at  DateTime(tz) UTC
    %%   created_by_id_user / updated_by_id_user / deleted_by_id_user Integer FK nullable
    %% FKs entre tablas usan Integer (id del padre). Ver docs/decisions/010-database-id-strategy.md
    %% Solo se muestran columnas específicas de cada entidad

    %% REFERENCIAS EXTERNAS
    %% person: definida en schema people

    %% RELACIONES
    person ||--o{ auth_factor : "has_factors"
    person ||--o{ otp_challenge : "receives"
    person ||--o{ recovery_code : "has_backup"
    auth_factor ||--o{ otp_challenge : "generates"

    %% ENUMS
    EFactorType {
        String TOTP "TOTP"
        String SMS "SMS"
        String EMAIL "EMAIL"
        String RECOVERY_CODE "RECOVERY_CODE"
    }

    EOtpChannel {
        String SMS "SMS"
        String EMAIL "EMAIL"
        String TOTP "TOTP"
    }

    EOtpPurpose {
        String LOGIN "LOGIN"
        String RESET_PASSWORD "RESET_PASSWORD"
        String SENSITIVE_ACTION "SENSITIVE_ACTION"
        String ONBOARDING "ONBOARDING"
    }

    %% ENTIDADES
    %% auth_factor: metodo MFA habilitado por persona
    %% secret: seed TOTP o valor encriptado (SIEMPRE encriptado, nunca texto plano)
    %% is_primary: factor principal (recomendado: TOTP, fallback: SMS o EMAIL)
    auth_factor {
        Integer id_person FK
        Enum(EFactorType) type
        Text secret
        String phone
        String email
        Boolean verified
        Boolean is_primary
        DateTime last_used_at
    }

    %% otp_challenge: desafio OTP temporal (expira en 1-5 minutos)
    %% code_hash: hash del codigo OTP (nunca raw code)
    %% single-use: se invalida al consumirse
    %% id_factor: FK a auth_factor (el metodo MFA que genero el desafio). nullable cuando
    %%   el OTP no proviene de un factor MFA registrado (ej. purpose=ONBOARDING o RESET_PASSWORD,
    %%   donde el usuario aun no tiene factores configurados y el codigo se envia por email/SMS directo).
    otp_challenge {
        Integer id_person FK
        Integer id_factor "FK nullable — ver comentario arriba"
        Text code_hash
        String destination
        Enum(EOtpChannel) channel
        Enum(EOtpPurpose) purpose
        DateTime expires_at
        Boolean used
        DateTime consumed_at
    }

    %% recovery_code: codigos de respaldo de emergencia
    %% Se generan una sola vez, se muestran al usuario una vez
    %% code_hash: hash del codigo (nunca texto plano)
    %% single-use: se invalida al consumirse
    recovery_code {
        Integer id_person FK
        Text code_hash
        Boolean used
        DateTime used_at
    }
