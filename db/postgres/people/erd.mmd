erDiagram
    %% PEOPLE SCHEMA
    %% Tablas relacionadas con datos demograficos y contacto de personas

    %% BaseModel (heredado por todas las entidades no-intermediarias):
    %%   id     Integer PK autoincrement  — interno, NUNCA expuesto en API
    %%   uuid   UUID auto-generado       — externo, usado en respuestas y rutas de API
    %%   created_at / updated_at / deleted_at  DateTime(tz) UTC
    %%   created_by_id_user / updated_by_id_user / deleted_by_id_user  Integer FK nullable (pendiente IAM)
    %%
    %% Convención de FKs: siempre Integer (id del padre), nunca UUID.
    %% Ver docs/decisions/010-database-id-strategy.md

    %% RELACIONES PRINCIPALES
    person ||--o{ email : "has"
    person ||--o{ phone : "has"
    person ||--o{ address : "has"
    person ||--o{ social_links : "has"
    person ||--o{ profile : "has"
    person ||--|| birth : "has_birth_info"
    person ||--|| sociocultural_identity : "has_sociocultural_identity"
    person ||--|| legal_info : "has_legal_info"
    person ||--o{ personal_identifier : "has"
    person ||--|| user : "has"
    person ||--o{ emergency_contact : "has_emergency"

    %% RELACIONES SECUNDARIAS
    social_platform ||--o{ social_links : "has"
    identifier_type ||--o{ personal_identifier : "has"

    %% ENUMS
    %% EVerificationStatus: estado de verificacion (REJECTED, PENDING, APPROVED)
    %% EGenderIdentity: identidad de genero (NO_ESPECIFICADO=0, MASCULINO=1, FEMENINO=2, TRANSGENERO=3, TRANSEXUAL=4, TRAVESTI=5, INTERSEXUAL=6, OTRO=88)
    %% EEducationLevel: nivel educativo (NO_STUDIES=0, PRIMARY=1, SECONDARY=2, HIGH_SCHOOL=3, UNIVERSITY=4, POSTGRADUATE=5, PREFERS_NOT_TO_SAY=99)
    %% EIncomeRange: rango de ingresos (<5000, 5000-9999, 10000-19999, 20000-39999, >=40000, PREFERS_NOT_TO_SAY)
    %% ESocialPlatform: plataformas sociales (twitter, linkedin, github, facebook, instagram, youtube, tiktok, personal_website, other)
    %% EIdentifierType: tipos de identificador (NATIONAL_ID=1, FISCAL_ID=2, SOCIAL_SECURITY_ID=3)
    %% EAddressType: tipos de direccion (HOME=1, WORK=2, BUSINESS=3, OTHER=10)
    %% EEmailType: tipos de email (PERSONAL=2, WORK=3, BUSINESS=4, OTHER=10)
    %% EPhoneType: tipos de telefono (MOBILE=1, WORK=2, HOME=3, BUSINESS=4, OTHER=10)
    %% ERelationshipContact: tipo de relacion de contacto (SPOUSE, PARENT, SIBLING, CHILD, FRIEND, CAREGIVER, OTHER)
    %% EOccupationType: tipo de ocupacion (EMPLOYED, SELF_EMPLOYED, FREELANCE, HOMEMAKER, UNEMPLOYED, RETIRED, OTHER, PREFERS_NOT_TO_SAY)
    %% ECivilStatus: estado civil (SINGLE, MARRIED, COMMON_LAW, SEPARATED, DIVORCED, WIDOWED, PREFERS_NOT_TO_SAY)
    EVerificationStatus {
        String REJECTED "REJECTED"
        String PENDING "PENDING"
        String APPROVED "APPROVED"
    }

    EGenderIdentity {
        Integer NO_ESPECIFICADO "0"
        Integer MASCULINO "1"
        Integer FEMENINO "2"
        Integer TRANSGENERO "3"
        Integer TRANSEXUAL "4"
        Integer TRAVESTI "5"
        Integer INTERSEXUAL "6"
        Integer OTRO "88"
    }

    EEducationLevel {
        Integer NO_STUDIES "0"
        Integer PRIMARY "1"
        Integer SECONDARY "2"
        Integer HIGH_SCHOOL "3"
        Integer UNIVERSITY "4"
        Integer POSTGRADUATE "5"
        Integer PREFERS_NOT_TO_SAY "99"
    }

    EIncomeRange {
        Integer NO_INCOME "0"
        Integer UNDER_5000 "1"
        Integer FROM_5000_TO_9999 "2"
        Integer FROM_10000_TO_19999 "3"
        Integer FROM_20000_TO_39999 "4"
        Integer FROM_40000 "5"
        Integer PREFERS_NOT_TO_SAY "99"
    }

    ESocialPlatform {
        String TWITTER "twitter"
        String LINKEDIN "linkedin"
        String GITHUB "github"
        String FACEBOOK "facebook"
        String INSTAGRAM "instagram"
        String YOUTUBE "youtube"
        String TIKTOK "tiktok"
        String PERSONAL_WEBSITE "personal_website"
        String OTHER "other"
    }

    EIdentifierType {
        Integer NATIONAL_ID "1"
        Integer FISCAL_ID "2"
        Integer SOCIAL_SECURITY_ID "3"
    }

    EAddressType {
        Integer HOME "1"
        Integer WORK "2"
        Integer BUSINESS "3"
        Integer OTHER "10"
    }

    EEmailType {
        Integer PERSONAL "2"
        Integer WORK "3"
        Integer BUSINESS "4"
        Integer OTHER "10"
    }

    EPhoneType {
        Integer MOBILE "1"
        Integer WORK "2"
        Integer HOME "3"
        Integer BUSINESS "4"
        Integer OTHER "10"
    }

    ERelationshipContact {
        String SPOUSE "SPOUSE"
        String PARENT "PARENT"
        String SIBLING "SIBLING"
        String CHILD "CHILD"
        String FRIEND "FRIEND"
        String CAREGIVER "CAREGIVER"
        String OTHER "OTHER"
    }

    EOccupationType {
        Integer EMPLOYED "1"
        Integer SELF_EMPLOYED "2"
        Integer FREELANCE "3"
        Integer HOMEMAKER "4"
        Integer UNEMPLOYED "5"
        Integer RETIRED "6"
        Integer OTHER "88"
        Integer PREFERS_NOT_TO_SAY "99"
    }

    ECivilStatus {
        Integer SINGLE "1"
        Integer MARRIED "2"
        Integer COMMON_LAW "3"
        Integer SEPARATED "4"
        Integer DIVORCED "5"
        Integer WIDOWED "6"
        Integer PREFERS_NOT_TO_SAY "99"
    }

    %% ENTIDADES
    %% person: tabla central con datos demograficos
    %% verification_status: estado de verificacion del perfil
    %% type_gender: identidad de genero
    person {
        Integer id PK
        UUID uuid
        Enum(EVerificationStatus) verification_status "default: PENDING"
        String url_photo
        String first_name
        String last_name
        String second_last_name
        Enum(EGenderIdentity) type_gender "default: NO_ESPECIFICADO"
    }

    %% email: correos electronicos de contacto
    %% type_email: tipo de correo (PERSONAL, WORK, BUSINESS, OTHER)
    email {
        Integer id PK
        UUID uuid
        Integer id_person FK
        String email
        Enum(EEmailType) type_email
    }

    %% phone: telefonos de contacto
    %% code: codigo de pais + lada (ej: +52)
    %% number: numero sin codigo
    phone {
        Integer id PK
        UUID uuid
        Integer id_person FK
        String code
        String number
        Enum(EPhoneType) type_phone
    }

    %% address: direcciones geograficas
    %% type_address: tipo de direccion (HOME, WORK, BUSINESS, OTHER)
    %% key_country/state/municipality/colony: claves geograficas (catalog)
    address {
        Integer id PK
        UUID uuid
        Integer id_person FK
        Enum(EAddressType) type_address
        String(20) key_country FK
        String(20) key_state FK
        String(20) key_municipality FK
        String(20) key_colony FK
        String(191) address
        String(191) address_complement
        String(10) postal_code
        Float latitude
        Float longitude
    }

    %% social_platform: catalogo de plataformas sociales
    %% name: tipo de plataforma (enum)
    social_platform {
        Integer id PK
        UUID uuid
        Enum(ESocialPlatform) name
        String url_icon
        Boolean is_active
    }

    %% social_links: enlaces a redes sociales por persona
    %% id_platform: tipo de plataforma (enum)
    %% order_display: orden de prioridad para mostrar
    social_links {
        Integer id PK
        UUID uuid
        Integer id_person FK
        Integer id_platform FK
        String url_profile
        Boolean is_verified
        Integer order_display
    }

    %% profile: perfil profesional/laboral
    %% known_as: apodo o nombre artistico
    %% education_level: nivel educativo mas alto completado
    %% income_range: rango de ingresos economicos
    %% occupation_type: categoria de ocupacion (enum)
    %% occupation_other: descripcion libre si occupation_type = OTHER
    profile {
        Integer id PK
        UUID uuid
        Integer id_person FK
        Enum(EOccupationType) occupation_type
        String(100) occupation_other
        String known_as
        Enum(EEducationLevel) education_level
        Enum(EIncomeRange) income_range
        Text about_me
    }

    %% birth: informacion de nacimiento
    %% key_birth_country/state: claves geograficas de origen
    birth {
        Integer id PK
        UUID uuid
        Integer id_person FK
        String(20) key_birth_country FK
        String(20) key_state_birth FK
        Date birth_date
        String birth_date_timezone
    }

    %% sociocultural_identity: identidad sociocultural
    %% self_considers_indigenous: si se considera indigena (si/no)
    %% key_indigenous_language: idioma indigena (catalog)
    %% self_considers_migrant: si es migrante (si/no)
    sociocultural_identity {
        Integer id PK
        UUID uuid
        Integer id_person FK
        Boolean self_considers_indigenous
        String(20) key_indigenous_language FK
        Boolean self_considers_migrant
        String(20) key_country_origin FK
        String(20) key_religion FK
        String(100) religion_other
    }

    %% legal_info: informacion legal
    %% key_nationality: clave de nacionalidad (catalog)
    %% civil_status: estado civil (enum ECivilStatus, nullable = prefiere no decirlo)
    legal_info {
        Integer id PK
        UUID uuid
        Integer id_person FK
        String type_national_id_sex
        Enum(ECivilStatus) civil_status
        String(20) key_nationality FK
    }

    %% personal_identifier: identificadores oficiales (CURP, RFC, NSS, pasaporte, etc)
    %% id_identifier_type: tipo de identificador (enum)
    %% id_document: documento de respaldo (FK a document, nullable)
    personal_identifier {
        Integer id PK
        UUID uuid
        Enum(EIdentifierType) id_identifier_type FK
        Integer id_person FK
        String identifier_value
        UUID id_document FK
    }

    %% identifier_type: catalogo de tipos de identificador
    %% type_identifier: tipo como enum (NATIONAL_ID, FISCAL_ID, SOCIAL_SECURITY_ID)
    identifier_type {
        Integer id PK
        UUID uuid
        Enum(EIdentifierType) type_identifier
        String name
        String abbreviation
        String(5) country_code
    }

    %% emergency_contact: contactos de emergencia
    %% id_user_owner: usuario propietario del contacto
    %% id_contact_user: si existe, FK a user (nullable)
    %% first_name/last_name: snapshot del contacto (nullable si es user)
    %% relationship_type: tipo de relacion (enum)
    emergency_contact {
        Integer id PK
        UUID uuid
        Integer id_user_owner FK
        Integer id_contact_user FK
        String first_name
        String last_name
        String phone_number
        String email
        Enum(ERelationshipContact) relationship_type
        String(100) relationship_other
        Text notes
    }

    %% user: cuenta de usuario del sistema
    %% 1:1 con person
    user {
        Integer id PK
        UUID uuid
        Integer id_person FK
        String username
        String password_hash
        Boolean is_active
    }