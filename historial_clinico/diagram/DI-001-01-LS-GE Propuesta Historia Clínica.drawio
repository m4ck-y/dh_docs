);&quot;&gt;VERDE&lt;/span&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: light-dark(rgb(255, 255, 255), rgb(154, 199, 191));&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(255, 255, 255), rgb(0, 0, 0));&quot;&gt;5. VALOR CONDICIONAL&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;background-color: light-dark(rgb(255, 255, 255), rgb(153, 153, 255)); color: light-dark(rgb(0, 0, 0), rgb(0, 0, 0));&quot;&gt;6. INDICACIONES, NO REQUIERE RESPUESTA&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 204, 230)); background-color: light-dark(rgb(255, 255, 255), rgb(255, 0, 128));&quot;&gt;7. dato ya ingresado en la información personal del pre-registro del usuario&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: light-dark(rgb(255, 255, 255), rgb(255, 0, 128));&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 204, 230));&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: rgb(0, 0, 0); background-color: rgb(255, 217, 102);&quot;&gt;AMARILLO&lt;/font&gt;&lt;span style=&quot;background-color: light-dark(rgb(255, 255, 255), rgb(84, 51, 0));&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0); background-color: rgb(255, 217, 102);&quot;&gt;.&lt;/font&gt; COSAS POR VERIFICAR CON UN EXPERTO&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: rgb(225, 213, 231);&quot;&gt;LILA&lt;/span&gt;&lt;span style=&quot;background-color: light-dark(rgb(255, 255, 255), rgb(57, 47, 63));&quot;&gt;&lt;span style=&quot;background-color: rgb(225, 213, 231);&quot;&gt;.&lt;/span&gt; SUGERENCIAS PENDIENTES DE REVISIÓN&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;&lt;b style=&quot;background-color: rgb(255, 217, 102);&quot;&gt;&lt;font style=&quot;color: rgb(153, 0, 0);&quot;&gt;??&amp;nbsp;&lt;/font&gt;&lt;/b&gt;&lt;span style=&quot;background-color: light-dark(rgb(255, 255, 2