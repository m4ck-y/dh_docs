        <mxCell id="_tAaDdRgz5of-5c-9y1_-16" parent="_tAaDdRgz5of-5c-9y1_-14" style="shape=partialRectangle;html=1;whiteSpace=wrap;connectable=0;strokeColor=inherit;overflow=hidden;fillColor=none;top=0;left=0;bottom=0;right=0;pointerEvents=1;" value="Crema. Preparación líquida o semisólida que contiene el o los fármacos y aditivos necesarios para obtener una emulsión, generalmente aceite en agua, comúnmente con un contenido de agua superior al 20 %." vertex="1">
