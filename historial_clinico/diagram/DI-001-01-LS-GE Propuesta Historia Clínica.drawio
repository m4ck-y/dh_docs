        <mxCell id="_tAaDdRgz5of-5c-9y1_-73" parent="_tAaDdRgz5of-5c-9y1_-71" style="shape=partialRectangle;html=1;whiteSpace=wrap;connectable=0;strokeColor=inherit;overflow=hidden;fillColor=none;top=0;left=0;bottom=0;right=0;pointerEvents=1;" value="&amp;nbsp;Forma sólida que contiene el o los fármacos y aditivos, finamente molidos y mezclados para asegurar su homogeneidad. Los polvos para uso en inyectables deben ser estériles y libres de partículas extrañas.&amp;nbsp;" vertex="1">
          <mxGeometry height="60" width="570" x="140" as="geometry">
