        <mxCell id="OPMiEJOnCLoR4la2KIH1-233" parent="OPMiEJOnCLoR4la2KIH1-1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=15;" value="&lt;div style=&quot;text-align: center;&quot;&gt;&lt;b style=&quot;background-color: light-dark(rgb(255, 255, 255), rgb(255, 255, 255));&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(0, 0, 0));&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;DEFINICIÓN DE COLORES&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;&amp;nbsp;&lt;/font&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp;&lt;br&gt;1. PREGUNTAS Y RESPUESTAS SIN CONDICIONALES &amp;lt;- MISMO COLOR (BORDE NEGRO)&lt;div&gt;&lt;span style=&quot;background-color: light-dark(rgb(255, 255, 255), rgb(5, 48, 62));&quot;&gt;2. PREGUNTA CONDICIONAL &amp;lt;- &lt;span style=&quot;background-color: rgb(188, 239, 255);&quot;&gt;A&lt;/span&gt;&lt;/span&gt;&lt;span style=&quot;background-color: rgb(188, 239, 255);&quot;&gt;ZUL&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;background-color: light-dark(rgb(255, 255, 255), rgb(49, 158, 255));&quot;&gt;3. RESPUESTAS (POSIBLES CAMINOS DE LA RESPUESTA) &amp;lt;-&lt;/span&gt; &lt;span style=&quot;background-color: rgb(0, 127, 255);&quot;&gt;&lt;font&gt;AZUL&lt;/font&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;&lt;font style=&quot;color: light-dark(rgb(255, 255, 255), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;background-color: light-dark(rgb(255, 255, 255), rgb(26, 97, 102));&quot;&gt;4. DATOS CONDICIONALES EXISTENTES &amp;lt;- &lt;/span&gt;&lt;span style=&quot;background-color: light-dark(rgb(255, 255, 255), rgb(26, 97, 102));&quot;&gt;VERDE&lt;/span&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: light-dark(rgb(255, 255, 255), rgb(154, 199, 191));&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(255, 255, 255), rgb(0, 0, 0));&quot;&gt;5. VALOR CONDICIONAL&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;background-color: light-dark(rgb(255, 255, 255), rgb(153, 153, 255)); color: light-dark(rgb(0, 0, 0), rgb(0, 0, 0));&quot;&gt;6. INDICACIONES, NO REQUIERE RESPUESTA&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 204, 230)); background-color: light-dark(rgb(255, 255, 255), rgb(255, 0, 128));&quot;&gt;7. dato ya ingresado en la información personal del pre-registro del usuario&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: light-dark(rgb(18, 18, 18), rgb(255, 255, 255));&quot;&gt;&lt;font style=&quot;background-color: light-dark(rgb(255, 255, 255), rgb(234, 107, 102));&quot;&gt;8. selección mú&lt;/font&gt;&lt;font style=&quot;background-color: light-dark(rgb(255, 255, 255), rgb(234, 107, 102));&quot;&gt;ltiple&lt;/font&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: light-dark(rgb(255, 255, 255), rgb(255, 0, 128));&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 204, 230));&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: rgb(0, 0, 0); background-color: rgb(255, 217, 102);&quot;&gt;AMARILLO&lt;/font&gt;&lt;span style=&quot;background-color: light-dark(rgb(255, 255, 255), rgb(84, 51, 0));&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0); background-color: rgb(255, 217, 102);&quot;&gt;.&lt;/font&gt; COSAS POR VERIFICAR CON UN EXPERTO&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: rgb(225, 213, 231);&quot;&gt;LILA&lt;/span&gt;&lt;span style=&quot;background-color: light-dark(rgb(255, 255, 255), rgb(57, 47, 63));&quot;&gt;&lt;span style=&quot;background-color: rgb(225, 213, 231);&quot;&gt;.&lt;/span&gt; SUGERENCIAS PENDIENTES DE REVISIÓN&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;&lt;b style=&quot;background-color: rgb(255, 217, 102);&quot;&gt;&lt;font style=&quot;color: rgb(153, 0, 0);&quot;&gt;??&amp;nbsp;&lt;/font&gt;&lt;/b&gt;&lt;span style=&quot;background-color: light-dark(rgb(255, 255, 255), rgb(84, 51, 0));&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 181, 181));&quot;&gt;&lt;b style=&quot;&quot;&gt;&amp;nbsp;&lt;/b&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;POR VERIFICAR/COMENTAR CON EL EQUIPO&lt;/font&gt;&lt;/font&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(153, 0, 0); font-family: monospace; font-size: 0px; text-wrap-mode: nowrap;&quot;&gt;%3CmxGraphModel%3E%3Croot%3E%3CmxCell%20id%3D%220%22%2F%3E%3CmxCell%20id%3D%221%22%20parent%3D%220%22%2F%3E%3CmxCell%20id%3D%222%22%20value%3D%22%3F%3F%3F%3F%22%20style%3D%22text%3Bhtml%3D1%3BwhiteSpace%3Dwrap%3BstrokeColor%3D%23BD7000%3BfillColor%3D%23f0a30a%3Balign%3Dcenter%3BverticalAlign%3Dmiddle%3Brounded%3D0%3BfontSize%3D15%3BfontStyle%3D1%3BfontColor%3D%23990000%3B%22%20vertex%3D%221%22%20parent%3D%221%22%3E%3CmxGeometry%20x%3D%228176%22%20y%3D%221565%22%20width%3D%2260%22%20height%3D%2230%22%20as%3D%22geometry%22%2F%3E%3C%2FmxCell%3E%3C%2Froot%3E%3C%2FmxGraphModel%3E&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
