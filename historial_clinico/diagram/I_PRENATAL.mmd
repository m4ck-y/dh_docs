    Q5.List --> Q6.0{6.0 ¿En dónde atendieron su parto?}
    Q6.0 --> Q6.List[Hospital, Consultorio, Casa, Otro]
    
    Q6.List --> Q7.0{7.0 ¿Tuvo alguna complicación durante el embarazo?}
    Q7.0 -- SÍ --> Q7.1[SÍ - Especifique]
    Q7.0 -- NO --> Q8.0
    
    Q7.1 --> Q8.0{8.0 ¿Tuvo alguna complicación durante el parto?}
    Q8.0 -- SÍ --> Q8.1[SÍ - Especifique]
    Q8.0 -- NO --> End
    
    Q8.1 --> End
